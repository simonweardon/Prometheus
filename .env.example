# ─── Google Calendar / Meet Integration ───────────────────────────────────────
#
# 1. Go to https://console.cloud.google.com and create (or select) a project.
# 2. Enable the "Google Calendar API" for that project.
# 3. Create a Service Account: IAM & Admin → Service Accounts → Create.
# 4. Add a JSON key to the service account and paste the whole key file contents
#    as a single-line JSON string below.
# 5. In Google Calendar, open Settings for the calendar you want to book into,
#    go to "Share with specific people", and add the service account email with
#    "Make changes to events" permission.
# 6. Copy the Calendar ID from that same Settings page.
#
# The scheduler uses conferenceDataVersion=1 so Google automatically creates a
# Meet link for every new event.

GOOGLE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"abc123","private_key":"-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----\n","client_email":"prometheus-scheduler@your-project.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/prometheus-scheduler%40your-project.iam.gserviceaccount.com"}

# The Google Calendar ID to book into (usually the host's email address or the
# calendar's ID from its Settings page)
GOOGLE_CALENDAR_ID=engage@prometheus-ai.com

# Email address of the Prometheus host — added as a co-attendee on every event
# so they receive the calendar invite and can see the Meet link
CALENDAR_OWNER_EMAIL=engage@prometheus-ai.com

# ─── Web server ───────────────────────────────────────────────────────────────
PORT=80
