PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret

# Admin account provisioned on startup (idempotent — also resets the password).
# Set these to create your own staff login when the app starts.
# ADMIN_EMAIL=simon@getprometheussolutions.com
# ADMIN_PASSWORD=change-this-to-a-strong-password
# ADMIN_NAME=Simon

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: absolute path to SQLite file (defaults to db/prometheus.db)
# DB_PATH=/data/prometheus.db

# Optional: restrict CORS to your frontend origin
# CORS_ORIGIN=https://yourdomain.com
