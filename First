<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prometheus — We Bring the Fire</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,600&family=Cinzel:wght@400;500&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ember:    #C4622D;
  --ember-lt: #E8854A;
  --gold:     #C9A44A;
  --gold-lt:  #E8C97A;
  --ash:      #1A1410;
  --soot:     #0D0B08;
  --smoke:    #2E2520;
  --ivory:    #F0EAE0;
  --parchment:#D4C9B0;
  --warm-gray:#8A7D6E;
  --serif:    'Cormorant Garamond', Georgia, serif;
  --display:  'Cinzel', serif;
  --sans:     'Lato', sans-serif;
}

html { scroll-behavior: smooth; }

body {
  background: var(--soot);
  color: var(--ivory);
  font-family: var(--sans);
  font-weight: 300;
  overflow-x: hidden;
}

/* ─── GRAIN OVERLAY ─── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
  opacity: 0.4;
}

/* ─── NAV ─── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2rem 4rem;
  background: linear-gradient(to bottom, rgba(13,11,8,0.92) 0%, transparent 100%);
}

.logo {
  font-family: var(--display);
  font-size: 1.4rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  color: var(--ivory);
  text-decoration: none;
  text-transform: uppercase;
}

.logo span {
  color: var(--ember);
}

.nav-links {
  display: flex;
  gap: 3rem;
  list-style: none;
}

.nav-links a {
  font-family: var(--sans);
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--parchment);
  text-decoration: none;
  opacity: 0.8;
  transition: opacity 0.3s, color 0.3s;
}

.nav-links a:hover {
  opacity: 1;
  color: var(--gold-lt);
}

.nav-cta {
  font-family: var(--sans);
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--soot);
  background: var(--ember);
  padding: 0.7rem 1.8rem;
  text-decoration: none;
  transition: background 0.3s;
}

.nav-cta:hover { background: var(--ember-lt); }

/* ─── HERO ─── */
.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  display: flex;
  align-items: flex-end;
  padding: 0 4rem 7rem;
  overflow: hidden;
}

/* The painting canvas — CSS art of a figure in firelight */
.hero-painting {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-painting canvas {
  width: 100%;
  height: 100%;
}

/* Deep atmospheric layers */
.hero-sky {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 68% 30%, rgba(160,70,20,0.55) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 65% 38%, rgba(220,120,40,0.4) 0%, transparent 50%),
    radial-gradient(ellipse 100% 80% at 50% 0%, rgba(60,30,10,0.9) 0%, transparent 70%),
    linear-gradient(to bottom, #0D0B08 0%, #1a0e06 35%, #2a1508 55%, #1a0d05 100%);
}

/* Oil-painting-style fire glow — warm light source center-right */
.hero-glow {
  position: absolute;
  top: 15%; right: 20%;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle,
    rgba(255,180,60,0.28) 0%,
    rgba(220,100,30,0.20) 30%,
    rgba(160,50,10,0.10) 55%,
    transparent 70%
  );
  mix-blend-mode: screen;
  pointer-events: none;
  animation: breathe 4s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.9; }
  50%       { transform: scale(1.06); opacity: 1; }
}

/* Silhouette figure — oil painting style with SVG */
.hero-figure {
  position: absolute;
  right: 8%;
  bottom: 0;
  width: 45%;
  height: 90%;
  pointer-events: none;
}

/* Ground plane */
.hero-ground {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 30%;
  background: linear-gradient(to top,
    rgba(8,4,2,0.95) 0%,
    rgba(20,10,4,0.6) 40%,
    transparent 100%
  );
}

.hero-content {
  position: relative;
  z-index: 5;
  max-width: 640px;
}

.hero-eyebrow {
  font-family: var(--sans);
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--ember-lt);
  margin-bottom: 1.8rem;
  display: flex;
  align-items: center;
  gap: 1.2rem;
}

.hero-eyebrow::before {
  content: '';
  display: block;
  width: 36px; height: 1px;
  background: var(--ember-lt);
  opacity: 0.7;
}

h1 {
  font-family: var(--serif);
  font-size: clamp(3.4rem, 6.5vw, 5.8rem);
  font-weight: 300;
  line-height: 1.04;
  color: var(--ivory);
  margin-bottom: 2rem;
  letter-spacing: -0.01em;
}

h1 em {
  font-style: italic;
  color: var(--gold-lt);
  font-weight: 300;
}

.hero-sub {
  font-size: 1.05rem;
  font-weight: 300;
  line-height: 1.85;
  color: var(--parchment);
  opacity: 0.85;
  max-width: 500px;
  margin-bottom: 3rem;
}

.cta-group {
  display: flex;
  gap: 1.5rem;
  align-items: center;
  flex-wrap: wrap;
}

.btn-fire {
  font-family: var(--sans);
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--soot);
  background: var(--ember);
  padding: 1rem 2.4rem;
  text-decoration: none;
  display: inline-block;
  transition: background 0.3s, transform 0.2s;
}
.btn-fire:hover { background: var(--ember-lt); transform: translateY(-1px); }

.btn-outline {
  font-family: var(--sans);
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--parchment);
  border: 1px solid rgba(212,201,176,0.3);
  padding: 1rem 2.4rem;
  text-decoration: none;
  display: inline-block;
  transition: border-color 0.3s, color 0.3s;
}
.btn-outline:hover { border-color: var(--gold-lt); color: var(--gold-lt); }

/* Scroll cue */
.hero-scroll-cue {
  position: absolute;
  bottom: 2.5rem;
  right: 4rem;
  z-index: 5;
  writing-mode: vertical-rl;
  font-family: var(--sans);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--warm-gray);
  display: flex;
  align-items: center;
  gap: 1rem;
  opacity: 0.6;
}
.hero-scroll-cue::after {
  content: '';
  width: 1px; height: 48px;
  background: linear-gradient(to bottom, var(--warm-gray), transparent);
}

/* ─── STATEMENT BAND ─── */
.statement {
  background: var(--ember);
  padding: 2rem 4rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.statement p {
  font-family: var(--serif);
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  font-weight: 400;
  font-style: italic;
  color: var(--ivory);
  text-align: center;
  letter-spacing: 0.01em;
  line-height: 1.5;
}

/* ─── SECTION FOUNDATIONS ─── */
section { padding: 8rem 4rem; }

.tag {
  font-family: var(--sans);
  font-size: 0.62rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ember-lt);
  margin-bottom: 1.2rem;
  display: flex;
  align-items: center;
  gap: 0.9rem;
}
.tag::before {
  content: '';
  display: block;
  width: 24px; height: 1px;
  background: var(--ember-lt);
}

h2 {
  font-family: var(--serif);
  font-size: clamp(2.2rem, 4vw, 3.6rem);
  font-weight: 300;
  line-height: 1.12;
  color: var(--ivory);
  margin-bottom: 1.5rem;
}

h2 em {
  font-style: italic;
  color: var(--gold-lt);
}

/* ─── HOW WE WORK ─── */
.how {
  background: var(--ash);
  padding: 8rem 4rem;
}

.how-intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: end;
  margin-bottom: 6rem;
}

.how-intro p {
  font-size: 1.05rem;
  line-height: 1.9;
  color: var(--parchment);
  opacity: 0.8;
}

/* Painting-style illustration panel */
.how-art {
  position: relative;
  height: 480px;
  overflow: hidden;
}

.how-art-canvas {
  width: 100%; height: 100%;
}

/* Steps */
.how-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.05);
}

.step {
  background: var(--ash);
  padding: 3rem 2.5rem;
  transition: background 0.4s;
  position: relative;
  overflow: hidden;
}

.step:hover { background: var(--smoke); }

.step-num {
  font-family: var(--display);
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  color: var(--ember);
  margin-bottom: 2rem;
}

.step-icon {
  width: 48px; height: 48px;
  margin-bottom: 1.8rem;
  opacity: 0.7;
}

.step-title {
  font-family: var(--serif);
  font-size: 1.55rem;
  font-weight: 400;
  color: var(--ivory);
  margin-bottom: 1rem;
  line-height: 1.2;
}

.step-body {
  font-size: 0.88rem;
  line-height: 1.8;
  color: var(--warm-gray);
}

.step-watermark {
  position: absolute;
  bottom: -1rem; right: -0.5rem;
  font-family: var(--serif);
  font-size: 8rem;
  font-weight: 300;
  color: rgba(255,255,255,0.025);
  line-height: 1;
  pointer-events: none;
}

/* ─── PAINTING BREAK — WORKSHOP SCENE ─── */
.painting-break {
  position: relative;
  height: 70vh;
  min-height: 500px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pb-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

.pb-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right,
    rgba(13,11,8,0.85) 0%,
    rgba(13,11,8,0.3) 50%,
    rgba(13,11,8,0.7) 100%
  );
}

.pb-content {
  position: relative; z-index: 2;
  text-align: center;
  max-width: 720px;
  padding: 0 2rem;
}

.pb-content h2 {
  font-size: clamp(2.5rem, 5vw, 4.2rem);
  margin-bottom: 1.5rem;
}

.pb-content p {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-style: italic;
  color: var(--parchment);
  line-height: 1.7;
  opacity: 0.85;
}

/* ─── AGENTS SECTION ─── */
.agents {
  background: var(--soot);
  padding: 8rem 4rem;
}

.agents-head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: end;
  margin-bottom: 5rem;
}

.agents-head p {
  font-size: 1rem;
  line-height: 1.9;
  color: var(--parchment);
  opacity: 0.8;
}

.agents-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.04);
}

.agent-card {
  background: var(--soot);
  padding: 3rem;
  position: relative;
  transition: background 0.4s;
  overflow: hidden;
}

.agent-card:hover { background: var(--ash); }

.agent-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 2px; height: 0;
  background: var(--ember);
  transition: height 0.5s ease;
}

.agent-card:hover::before { height: 100%; }

.agent-tag {
  font-family: var(--sans);
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ember-lt);
  margin-bottom: 1.5rem;
}

.agent-title {
  font-family: var(--serif);
  font-size: 1.7rem;
  font-weight: 400;
  color: var(--ivory);
  margin-bottom: 1rem;
  line-height: 1.2;
}

.agent-body {
  font-size: 0.9rem;
  line-height: 1.85;
  color: var(--warm-gray);
  margin-bottom: 1.5rem;
}

.agent-examples {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.agent-examples li {
  font-size: 0.8rem;
  color: var(--parchment);
  opacity: 0.6;
  padding-left: 1rem;
  position: relative;
}

.agent-examples li::before {
  content: '—';
  position: absolute; left: 0;
  color: var(--ember);
  opacity: 0.7;
}

/* ─── PROMETHEUS MYTH SECTION ─── */
.myth {
  background: var(--ash);
  padding: 8rem 4rem;
  position: relative;
  overflow: hidden;
}

.myth-bg-text {
  position: absolute;
  bottom: -8%;
  left: -2%;
  font-family: var(--display);
  font-size: clamp(8rem, 18vw, 14rem);
  font-weight: 400;
  letter-spacing: 0.05em;
  color: rgba(196,98,45,0.04);
  pointer-events: none;
  white-space: nowrap;
  text-transform: uppercase;
}

.myth-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 7rem;
  align-items: center;
  position: relative; z-index: 1;
}

.myth-text p {
  font-size: 1rem;
  line-height: 1.95;
  color: var(--parchment);
  opacity: 0.8;
  margin-bottom: 1.5rem;
}

.myth-pull {
  font-family: var(--serif);
  font-size: 1.55rem;
  font-style: italic;
  font-weight: 300;
  color: var(--gold-lt);
  line-height: 1.5;
  border-left: 2px solid var(--ember);
  padding-left: 2rem;
  margin: 2.5rem 0;
}

/* Oil painting portrait in myth section */
.myth-portrait {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
}

/* ─── TOOLS ─── */
.tools {
  background: var(--soot);
  padding: 8rem 4rem;
}

.tools-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 5rem;
}

.tools-head h2 { max-width: 500px; margin-bottom: 0; }

.tools-intro {
  max-width: 340px;
  font-size: 0.92rem;
  line-height: 1.85;
  color: var(--warm-gray);
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.06);
}

.tool-tile {
  background: var(--soot);
  padding: 2.8rem 2.4rem;
  position: relative;
  overflow: hidden;
  transition: background 0.3s;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.tool-tile:hover { background: var(--ash); }

.tool-tile::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, var(--ember) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s;
}

.tool-tile:hover::before { opacity: 1; }

.tool-category {
  font-family: var(--sans);
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ember-lt);
}

.tool-name {
  font-family: var(--serif);
  font-size: clamp(1.4rem, 2vw, 1.8rem);
  font-weight: 300;
  color: var(--ivory);
  line-height: 1.1;
}

.tool-body {
  font-size: 0.85rem;
  line-height: 1.8;
  color: var(--warm-gray);
  flex: 1;
}

.tool-use {
  font-family: var(--sans);
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  color: var(--ember-lt);
  padding-top: 1rem;
  border-top: 1px solid rgba(255,255,255,0.06);
}

@media (max-width: 1024px) {
  .tools-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .tools { padding: 5rem 1.5rem; }
  .tools-head { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  .tools-grid { grid-template-columns: 1fr; }
}

.result-bg {
  position: absolute;
  bottom: -1rem; right: -0.5rem;
  font-family: var(--serif);
  font-size: 9rem;
  color: rgba(255,255,255,0.025);
  line-height: 1;
  pointer-events: none;
}

/* ─── PROCESS PAINTING PANEL ─── */
.process-visual {
  position: relative;
  height: 60vh;
  min-height: 440px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  padding: 5rem 4rem;
}

.pv-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

.pv-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top,
    rgba(13,11,8,0.92) 0%,
    rgba(13,11,8,0.2) 60%,
    rgba(13,11,8,0.6) 100%
  );
}

.pv-content {
  position: relative; z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  width: 100%;
}

.pv-step {
  position: relative;
}

.pv-num {
  font-family: var(--display);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  color: var(--ember-lt);
  margin-bottom: 0.8rem;
}

.pv-title {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 400;
  color: var(--ivory);
  margin-bottom: 0.5rem;
}

.pv-body {
  font-size: 0.8rem;
  line-height: 1.7;
  color: var(--warm-gray);
}

/* Horizontal connector */
.pv-content::before {
  content: '';
  position: absolute;
  top: 0.45rem;
  left: 8%;
  right: 8%;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--ember), var(--ember), transparent);
  opacity: 0.2;
  pointer-events: none;
  z-index: -1;
}

/* ─── INDUSTRIES ─── */
.industries {
  background: var(--ash);
  padding: 8rem 4rem;
}

.industries-head { margin-bottom: 4rem; }

.industry-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.industry-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.8rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  cursor: default;
  transition: padding-left 0.4s;
  position: relative;
}

.industry-item:first-child { border-top: 1px solid rgba(255,255,255,0.06); }

.industry-item:hover { padding-left: 1.2rem; }

.industry-item::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 0;
  background: var(--ember);
  opacity: 0.12;
  transition: width 0.4s;
}

.industry-item:hover::before { width: 100%; }

.industry-name {
  font-family: var(--serif);
  font-size: 1.6rem;
  font-weight: 300;
  color: var(--ivory);
}

.industry-tag {
  font-family: var(--sans);
  font-size: 0.62rem;
  font-weight: 400;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--warm-gray);
}

.industry-arrow {
  font-size: 0.85rem;
  color: var(--ember-lt);
  opacity: 0;
  transform: translateX(-8px);
  transition: opacity 0.3s, transform 0.3s;
}

.industry-item:hover .industry-arrow { opacity: 1; transform: translateX(0); }

/* ─── CUSTOM SOFTWARE ─── */
.custom-software {
  background: var(--soot);
  padding: 8rem 4rem;
  border-top: 1px solid rgba(255,255,255,0.04);
}

.custom-software-head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: end;
  margin-bottom: 5rem;
}

.custom-software-head p {
  font-size: 1rem;
  line-height: 1.9;
  color: var(--parchment);
  opacity: 0.8;
}

.custom-software-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.04);
  margin-bottom: 4rem;
}

.software-card {
  background: var(--soot);
  padding: 3rem;
  position: relative;
  transition: background 0.4s;
  overflow: hidden;
}

.software-card:hover { background: var(--ash); }

.software-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 2px; height: 0;
  background: var(--gold);
  transition: height 0.5s ease;
}

.software-card:hover::before { height: 100%; }

.software-card-tag {
  font-family: var(--sans);
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.5rem;
}

.software-card-title {
  font-family: var(--serif);
  font-size: 1.7rem;
  font-weight: 400;
  color: var(--ivory);
  margin-bottom: 1rem;
  line-height: 1.2;
}

.software-card-body {
  font-size: 0.9rem;
  line-height: 1.85;
  color: var(--warm-gray);
  margin-bottom: 1.5rem;
}

.software-card-examples {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.software-card-examples li {
  font-size: 0.78rem;
  color: var(--parchment);
  opacity: 0.65;
  padding-left: 1rem;
  position: relative;
}

.software-card-examples li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--gold);
  opacity: 0.7;
}

.custom-software-cta {
  text-align: center;
  padding-top: 1rem;
}

.custom-software-cta p {
  font-family: var(--serif);
  font-size: 1.1rem;
  color: var(--parchment);
  opacity: 0.75;
  margin-bottom: 2rem;
  font-style: italic;
}

/* ─── CALL TO ACTION ─── */
.cta-section {
  position: relative;
  height: 60vh;
  min-height: 480px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.cta-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

.cta-overlay {
  position: absolute;
  inset: 0;
  background: rgba(13,11,8,0.72);
}

.cta-content {
  position: relative; z-index: 2;
  text-align: center;
  max-width: 640px;
  padding: 0 2rem;
}

.cta-content h2 { font-size: clamp(2.4rem, 5vw, 4rem); margin-bottom: 1.2rem; }

.cta-content p {
  font-size: 1.05rem;
  line-height: 1.8;
  color: var(--parchment);
  opacity: 0.8;
  margin-bottom: 2.5rem;
}

/* ─── FOOTER ─── */
footer {
  background: var(--soot);
  border-top: 1px solid rgba(255,255,255,0.05);
  padding: 5rem 4rem 3rem;
}

.footer-top {
  display: grid;
  grid-template-columns: 1.8fr 1fr 1fr 1fr;
  gap: 4rem;
  margin-bottom: 4rem;
  padding-bottom: 4rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.footer-brand .logo { display: block; margin-bottom: 1.2rem; }

.footer-brand p {
  font-size: 0.88rem;
  line-height: 1.8;
  color: var(--warm-gray);
  max-width: 280px;
}

.footer-col-head {
  font-family: var(--sans);
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ember-lt);
  margin-bottom: 1.5rem;
}

.footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; }

.footer-links a {
  font-size: 0.88rem;
  color: var(--warm-gray);
  text-decoration: none;
  transition: color 0.3s;
}

.footer-links a:hover { color: var(--ivory); }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-copy {
  font-family: var(--sans);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  color: rgba(138,125,110,0.5);
}

.footer-myth {
  font-family: var(--serif);
  font-style: italic;
  font-size: 1rem;
  color: rgba(196,98,45,0.35);
}

/* ─── SCROLL REVEALS ─── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.85s ease, transform 0.85s ease;
}
.revealed {
  opacity: 1;
  transform: translateY(0);
}

/* Staggered delays */
.d1 { transition-delay: 0.05s; }
.d2 { transition-delay: 0.15s; }
.d3 { transition-delay: 0.25s; }
.d4 { transition-delay: 0.35s; }

/* Hero entrance */
@keyframes heroIn {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-eyebrow { animation: heroIn 1s 0.3s ease both; }
.hero h1      { animation: heroIn 1s 0.5s ease both; }
.hero-sub     { animation: heroIn 1s 0.7s ease both; }
.cta-group    { animation: heroIn 1s 0.9s ease both; }

/* ─── CLIENTS BAR ─── */
.clients-bar {
  background: var(--ash);
  padding: 3.5rem 4rem;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.clients-label {
  font-family: var(--sans);
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--warm-gray);
  opacity: 0.55;
  text-align: center;
  margin-bottom: 2.5rem;
}

.clients-logos {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rem;
  flex-wrap: wrap;
}

.client-logo {
  opacity: 0.45;
  transition: opacity 0.35s;
}
.client-logo:hover { opacity: 0.75; }

@media (max-width: 768px) {
  .clients-bar { padding: 3rem 1.5rem; }
  .clients-logos { gap: 3rem; }
}
@media (max-width: 480px) {
  .clients-logos { flex-direction: column; gap: 2.5rem; align-items: center; }
}

/* ─── HAMBURGER BUTTON ─── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  z-index: 1002;
}
.nav-hamburger span {
  display: block;
  width: 22px;
  height: 1px;
  background: var(--ivory);
  transition: transform 0.3s, opacity 0.3s;
}
.nav-hamburger.active span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.nav-hamburger.active span:nth-child(2) { opacity: 0; }
.nav-hamburger.active span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

/* ─── MOBILE NAV OVERLAY ─── */
.nav-mobile-overlay {
